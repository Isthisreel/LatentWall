# Odyssey ML API Key
ODYSSEY_API_KEY=ody_your_api_key_here

# Vosk Model Path (Relative or Absolute)
VOSK_MODEL_PATH=backend/models/vosk-model-small-en-us-0.15

# CORS Allowed Origins (comma-separated list of frontend URLs)
# Leave empty for local development (defaults to allowing all origins).
# Set to your frontend URL(s) for production:
#   CORS_ORIGINS=https://your-frontend.com,https://www.your-frontend.com
# WARNING: Do NOT leave CORS_ORIGINS empty in production.
CORS_ORIGINS=

# Optional: Other Service Keys
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
